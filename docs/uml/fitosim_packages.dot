// Diagramma dei package di fitosim — struttura architetturale a tre layer.
//
// Versione di fine tappa 5 (chiusura fascia 2). Aggiunge rispetto alla
// versione precedente:
//   - Layer DOMAIN: il modulo `room` (entità Room, IndoorMicroclimate)
//     e il modulo `weather` (WeatherDay, dataclass del meteo giornaliero
//     usata da apply_balance_step_from_weather della sotto-tappa C).
//   - Layer SCIENCE: il modulo `indoor` (radiazione indoor categoriale
//     e continua); il modulo `et0` ora include Penman-Monteith fisico,
//     Penman-Monteith standard FAO-56, Hargreaves-Samani e il selettore
//     "best available" (compute_et).
//   - Layer IO/sensors: il file `ecowitt` fornisce tre adapter
//     (WH51/WH52 per il substrato, WN31 per il microclima indoor, env
//     outdoor per il meteo del balcone).
//
// Layout: io in alto (adapter di ingresso/uscita), domain al centro
// (logica di business), science in basso (fondamenta matematiche).
// Le dipendenze vanno tutte verso il basso, riflettendo il principio
// "domain dipende da science, io dipende da domain, mai il contrario".
//
// Per rigenerarlo: dot -Tpng fitosim_packages.dot -o fitosim_packages.png

digraph fitosim_packages {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box,
          margin="0.15,0.08"];
    edge [fontname="Helvetica", fontsize=8, color="#666666"];
    graph [fontname="Helvetica", fontsize=11];
    bgcolor="white";
    nodesep=0.35;
    ranksep=0.6;
    compound=true;
    splines=true;

    // ============================================================
    //  Layer IO — adapter di ingresso/uscita (in alto)
    // ============================================================
    subgraph cluster_io {
        label="io/  —  adapter di ingresso/uscita";
        style="filled,rounded";
        fillcolor="#FAF0E8";
        color="#E8923C";
        fontcolor="#8C4A0F";
        fontsize=12;
        margin=14;

        persistence [label="persistence\n(SQLite, schema v3)", fillcolor="#FCE5CD"];
        serialization [label="serialization\n(JSON v2)", fillcolor="#FCE5CD"];

        subgraph cluster_sensors {
            label="io/sensors/";
            style="filled,rounded";
            fillcolor="#FCF1E5";
            color="#E8923C";
            fontcolor="#8C4A0F";
            fontsize=10;
            margin=10;

            sensor_protocols [label="protocols\n(SoilSensor,\nEnvironmentSensor)", fillcolor="#FCE5CD"];
            sensor_types [label="types\n(SoilReading,\nEnvironmentReading)", fillcolor="#FCE5CD"];
            sensor_errors [label="errors\n(3 livelli\neccezioni)", fillcolor="#FCE5CD"];

            sensor_ecowitt [label="ecowitt\n(WH51/WH52,\nWN31, Env)", fillcolor="#FCE5CD"];
            sensor_openmeteo [label="openmeteo", fillcolor="#FCE5CD"];
            sensor_http [label="http_json\n(gateway ESP32)", fillcolor="#FCE5CD"];
            sensor_fixtures [label="fixtures\n(CSV)", fillcolor="#FCE5CD"];

            { rank=same; sensor_ecowitt; sensor_openmeteo; sensor_http; sensor_fixtures; }
            { rank=same; sensor_protocols; sensor_types; sensor_errors; }

            sensor_ecowitt -> sensor_protocols [arrowhead=empty, color="#E8923C"];
            sensor_openmeteo -> sensor_protocols [arrowhead=empty, color="#E8923C"];
            sensor_http -> sensor_protocols [arrowhead=empty, color="#E8923C"];
            sensor_fixtures -> sensor_protocols [arrowhead=empty, color="#E8923C"];
            sensor_protocols -> sensor_types [style=dashed];
        }

        { rank=same; persistence; serialization; sensor_protocols; }
    }

    // ============================================================
    //  Layer DOMAIN — oggetti di dominio (al centro)
    // ============================================================
    subgraph cluster_domain {
        label="domain/  —  oggetti di dominio e orchestrazione";
        style="filled,rounded";
        fillcolor="#E8F1F8";
        color="#2E75B6";
        fontcolor="#1F3864";
        fontsize=12;
        margin=14;

        garden [label="garden\n(Garden)", fillcolor="#1F3864", fontcolor="white",
                fontsize=11];
        pot [label="pot\n(Pot, Location,\nPotShape)", fillcolor="#D5E8F0"];
        species [label="species\n(Species, catalogo)", fillcolor="#D5E8F0"];
        room [label="room\n(Room, Indoor-\nMicroclimate,\nLightExposure)", fillcolor="#D5E8F0"];
        weather [label="weather\n(WeatherDay)", fillcolor="#D5E8F0"];
        alerts [label="alerts\n(Alert, regole pure)", fillcolor="#D5E8F0"];
        scheduling [label="scheduling\n(ScheduledEvent,\nWeatherDayForecast)", fillcolor="#D5E8F0"];
        scheduler [label="scheduler\n(pianificatore\nirrigazione fascia 1)", fillcolor="#D5E8F0"];

        { rank=same; pot; species; room; weather; alerts; scheduling; scheduler; }
    }

    // ============================================================
    //  Layer SCIENCE — modello matematico (in basso)
    // ============================================================
    subgraph cluster_science {
        label="science/  —  modello matematico FAO-56 esteso";
        style="filled,rounded";
        fillcolor="#F0F4E8";
        color="#7CB342";
        fontcolor="#33691E";
        fontsize=12;
        margin=14;

        substrate [label="substrate\n(Substrate,\nBaseMaterial,\ncompose_substrate)", fillcolor="#E8F0D8"];
        balance [label="balance\n(bilancio idrico\nFAO-56)", fillcolor="#E8F0D8"];
        et0 [label="et0\n(Penman-Monteith\n+ Hargreaves\n+ selettore)", fillcolor="#E8F0D8"];
        dual_kc [label="dual_kc\n(FAO-56\ncap. 7)", fillcolor="#E8F0D8"];
        pot_physics [label="pot_physics\n(Kp, geometrie)", fillcolor="#E8F0D8"];
        saucer [label="saucer\n(modello\nsottovaso)", fillcolor="#E8F0D8"];
        nutrition [label="nutrition\n(Kn,\nstato chimico)", fillcolor="#E8F0D8"];
        fertigation [label="fertigation", fillcolor="#E8F0D8"];
        calibration [label="calibration\n(da sensore)", fillcolor="#E8F0D8"];
        radiation [label="radiation", fillcolor="#E8F0D8"];
        indoor [label="indoor\n(radiazione\nindoor)", fillcolor="#E8F0D8"];

        { rank=same; substrate; balance; pot_physics; nutrition; saucer; indoor; }
        { rank=same; et0; dual_kc; fertigation; calibration; radiation; }
    }

    // ============================================================
    //  DIPENDENZE TRA LAYER (sempre verso il basso)
    // ============================================================

    // io → domain
    persistence -> garden [label="save/load"];
    serialization -> garden [label="export/import"];
    sensor_protocols -> pot [style=dashed, label="letture"];

    // domain → science (Pot è il punto di sutura principale)
    pot -> substrate;
    pot -> balance;
    pot -> dual_kc;
    pot -> pot_physics;
    pot -> saucer;
    pot -> nutrition;
    pot -> fertigation;
    pot -> calibration;
    pot -> et0 [style=dashed, label="selettore ET"];
    pot -> indoor [style=dashed, label="radiazione\nindoor"];
    species -> dual_kc [style=dashed];
    species -> et0 [style=dashed, label="rs, h"];

    // domain → domain
    garden -> pot;
    garden -> alerts;
    garden -> scheduling;
    garden -> room [label="contiene\n0..*"];
    garden -> weather [style=dashed, label="step\nfrom_weather"];
    pot -> room [style=dashed, label="vive\nin (indoor)"];
    pot -> weather [style=dashed];
    room -> indoor [style=dashed, label="LightExposure"];
    alerts -> pot [style=dashed, label="legge stato"];
    scheduler -> pot [style=dashed];

    // ============================================================
    //  LEGENDA
    // ============================================================
    subgraph cluster_legend {
        label="Legenda";
        style="filled,rounded";
        fillcolor="#F5F5F5";
        color="#999999";
        fontsize=10;
        margin=8;
        node [shape=plaintext, fillcolor=none, style=none, fontsize=9];

        legend [label=<
            <table border="0" cellborder="0" cellspacing="3">
                <tr><td align="left"><font color="#666666">→</font></td><td align="left">dipendenza diretta (import Python)</td></tr>
                <tr><td align="left"><font color="#666666">- - →</font></td><td align="left">dipendenza opzionale o indiretta</td></tr>
                <tr><td align="left"><font color="#E8923C">▷</font></td><td align="left">implementa il Protocol</td></tr>
                <tr><td align="left">■ scuro</td><td align="left">classe principale del layer</td></tr>
            </table>
        >];
    }
}
