# ============================================================================
#  fitosim — File di esempio per le variabili d'ambiente
# ============================================================================
#
# Questo file documenta tutte le variabili d'ambiente che fitosim può
# leggere per configurare l'accesso alle sorgenti di dati esterne.
#
# COME USARLO
# -----------
#
# Copia questo file nella stessa directory rinominandolo `.env`:
#
#     cp .env.example .env
#
# Poi apri `.env` con un editor di testo e sostituisci i valori
# fittizi con le tue credenziali reali. Il file `.env` non va MAI
# committato in git (è già nel .gitignore del progetto), perché
# contiene segreti che resterebbero accessibili nello storico per
# sempre se finissero in un commit.
#
# Il file `.env.example` invece va committato: serve come
# documentazione strutturata per chi installa fitosim per la prima
# volta e vuole sapere quali variabili impostare.
#
# COME FITOSIM CARICA QUESTO FILE
# -------------------------------
#
# fitosim non carica automaticamente il file `.env`: legge le
# variabili dal proprio `os.environ`, che è popolato dal sistema o
# dal processo che lancia fitosim. Per caricare il `.env` nel tuo
# script Python, hai due opzioni:
#
# 1. Caricamento manuale via `python-dotenv` (libreria esterna,
#    `pip install python-dotenv`):
#
#        from dotenv import load_dotenv
#        load_dotenv()  # legge .env nella directory corrente
#        # ... ora os.environ è popolata, fitosim può usarla
#
# 2. Esportazione dalle shell prima di lanciare lo script:
#
#        # bash/zsh:
#        set -a; source .env; set +a
#        python my_script.py
#
#        # oppure systemd se fitosim gira come servizio:
#        # nel .service file, EnvironmentFile=/path/to/.env
#
# La prima è più ergonomica per lo sviluppo, la seconda per la
# produzione su Termux/Pi/server.
#
# CONVENZIONE DI NOMENCLATURA
# ---------------------------
#
# Tutte le variabili usate da fitosim hanno il prefisso `FITOSIM_`
# seguito dal nome del provider. Questo evita collisioni con altre
# librerie: se hai `ECOWITT_API_KEY` settata per un altro tool, fitosim
# non la userà inadvertitamente.
#
# Per backward compatibility, fitosim accetta anche le variabili senza
# prefisso (es. `ECOWITT_APPLICATION_KEY`) come fallback, emettendo
# un DeprecationWarning. Nuove configurazioni dovrebbero sempre usare
# il prefisso.


# ============================================================================
#  Sezione 1 — Stazione meteo Ecowitt
# ============================================================================
#
# Variabili usate da:
#   - EcowittEnvironmentSensor (dati meteo della tua stazione)
#   - EcowittWH51SoilSensor (letture θ dei sensori di umidità del suolo)
#
# Entrambi gli adapter usano le stesse credenziali — una sola stazione
# Ecowitt serve sia i dati ambientali sia i WH51 collegati.
#
# COME OTTENERE QUESTE CREDENZIALI
# --------------------------------
#
# 1. Crea un account su https://www.ecowitt.net se non ne hai già uno.
#
# 2. Aggiungi la tua stazione meteo all'account tramite l'app
#    "WS View Plus" (Android/iOS) o "Ecowitt" (web). Hai bisogno
#    della stazione fisicamente raggiungibile per il setup iniziale.
#
# 3. Genera le chiavi API: vai su
#    https://api.ecowitt.net/index/login → API Key Manager.
#    Otterrai due valori:
#       - Application Key (lunga, ~32 caratteri esadecimali)
#       - User API Key (lunga simile)
#
# 4. Recupera il MAC della stazione: nell'app "WS View Plus" lo trovi
#    sotto "Device Management" oppure sul retro della console base.
#    È un identificativo a 12 caratteri esadecimali, formattato come
#    "AA:BB:CC:DD:EE:FF" o "AABBCCDDEEFF" (entrambe le forme funzionano).
#
# Nessuna di queste tre informazioni costa: l'API gratuita Ecowitt
# permette ~100 chiamate/giorno, più che sufficienti per il
# giardinaggio domestico (una chiamata ogni 15 minuti = 96/giorno).

FITOSIM_ECOWITT_APPLICATION_KEY=metti_qui_la_tua_application_key
FITOSIM_ECOWITT_API_KEY=metti_qui_la_tua_api_key
FITOSIM_ECOWITT_MAC=AA:BB:CC:DD:EE:FF


# ============================================================================
#  Sezione 2 — Open-Meteo
# ============================================================================
#
# Open-Meteo (https://open-meteo.com) NON richiede credenziali per il
# piano gratuito, che è ampiamente sufficiente per il giardinaggio
# domestico (~10000 chiamate/giorno per IP). OpenMeteoEnvironmentSensor
# funziona out-of-the-box senza alcuna configurazione.
#
# Variabile riservata per future estensioni
# -----------------------------------------
#
# Se in futuro userai il piano commerciale di Open-Meteo (per
# applicazioni con volumi elevati), la tua API key andrà in:
#
#     # FITOSIM_OPENMETEO_API_KEY=metti_qui_la_tua_api_key_commerciale
#
# Decommenta e popola SOLO se hai effettivamente sottoscritto il piano
# commerciale. Per uso domestico, lascia commentato e basta.


# ============================================================================
#  Sezione 3 — Sensori riservati per tappe future della fascia 2
# ============================================================================
#
# Le variabili in questa sezione NON sono ancora lette dal codice di
# fitosim. Sono qui come placeholder documentale per le tappe future
# della roadmap, in modo che tu sappia cosa impostare quando le tappe
# diventeranno disponibili.

# --- Tappa 2: ATO 7-in-1 (sensore avanzato di suolo) ----------------------
#
# Quando arriverà l'adapter ATO7in1SoilSensor (tappa 2 della fascia 2),
# leggerà le sue credenziali da queste variabili. ATO espone i dati via
# API HTTP del proprio cloud; le credenziali esatte saranno definite
# durante l'implementazione della tappa.
#
# # FITOSIM_ATO_API_KEY=metti_qui_la_chiave_quando_implementata
# # FITOSIM_ATO_DEVICE_ID=metti_qui_id_dispositivo

# --- Tappa 4: Persistenza del Garden (orchestratore) ----------------------
#
# Quando arriverà la tappa 4 (Garden orchestrator), il sistema dovrà
# persistere lo stato dei vasi su database SQLite tra sessioni. Il
# percorso del file di database sarà configurabile via:
#
# # FITOSIM_GARDEN_DB_PATH=/percorso/al/tuo/garden.sqlite


# ============================================================================
#  Sezione 4 — Verifiche di setup
# ============================================================================
#
# Per verificare che le tue credenziali siano lette correttamente,
# puoi eseguire questo piccolo script Python di diagnostica dopo
# aver popolato il .env:
#
#     PYTHONPATH=src python -c "
#     from fitosim.io.sensors import EcowittEnvironmentSensor
#     try:
#         sensor = EcowittEnvironmentSensor.from_env()
#         print('OK — credenziali Ecowitt lette correttamente')
#     except RuntimeError as e:
#         print(f'ERRORE: {e}')
#     "
#
# Se vedi 'OK', sei configurato bene. Se vedi un RuntimeError che
# elenca variabili mancanti, controlla che il .env sia stato caricato
# (vedi sezione 'COME FITOSIM CARICA QUESTO FILE' all'inizio).
#
# Per una verifica end-to-end che fa una vera chiamata all'API Ecowitt
# con le tue credenziali:
#
#     PYTHONPATH=src python -c "
#     from fitosim.io.sensors import EcowittEnvironmentSensor
#     sensor = EcowittEnvironmentSensor.from_env()
#     reading = sensor.current_conditions(latitude=45.46, longitude=9.19)
#     print(f'Temperatura attuale: {reading.temperature_c} °C')
#     print(f'Umidità: {reading.humidity_relative * 100:.0f}%')
#     "
